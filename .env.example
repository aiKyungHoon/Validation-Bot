# Telegram Bot Settings
# 아래 4개는 필수. 하나라도 비어 있으면 봇이 기동하지 않는다.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# 웹훅 URL 경로에 들어갈 무작위 문자열
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
WEBHOOK_SECRET=your_random_url_path_secret

# setWebhook의 secret_token 값. 텔레그램이 X-Telegram-Bot-Api-Secret-Token 헤더로 되돌려 준다.
# 규격: A-Z a-z 0-9 _ - 1~256자
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
TELEGRAM_SECRET_TOKEN=your_random_telegram_secret_token

# /summary 호출 시 X-Summary-Secret 헤더로 보내야 하는 값 (스케줄러 전용)
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SUMMARY_SECRET=your_random_summary_secret

SUMMARY_CHAT_ID=your_summary_chat_id

# 봇이 응답할 채팅방 ID 목록 (쉼표 구분). 여기 없는 그룹에 초대되면 봇이 자동으로 나간다.
# 비워두면 SUMMARY_CHAT_ID 하나만 허용된다. 예: -1001234567890,-1009876543210
ALLOWED_CHAT_IDS=

# 관리자 전용 명령(/목록, /topicid)을 쓸 수 있는 사용자 ID 목록 (쉼표 구분).
# 확인 방법: 허용된 채팅방에서 봇에게 /myid 를 보내면 본인 ID를 알려준다.
# 비워두면 관리자 명령은 아무도 쓸 수 없다. 예: 123456789,987654321
ADMIN_USER_IDS=

# Google Cloud Settings (for Topics/Threads)
USE_MESSAGE_THREAD_ID=false
DEFAULT_MESSAGE_THREAD_ID=
IGNORE_THREAD_IDS=12345,67890


# Google Sheets Settings
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Server Settings
PORT=8080
